# Copy these values into your deployment provider's environment settings.
# Do not commit real secrets or database credentials.

ENVIRONMENT=production

# Prefer DATABASE_URL in production. If not using DATABASE_URL, set all DB_* values.
DATABASE_URL=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=5432
DB_NAME=postgres

JWT_SECRET=change-this-to-a-long-random-production-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Comma-separated browser origins. Native mobile apps do not need CORS.
# Example: https://admin.yourdomain.com,https://staff.yourdomain.com
CORS_ORIGINS=
CORS_ALLOW_CREDENTIALS=false

# Comma-separated hostnames accepted by the API. Use * only if your platform
# terminates host validation before the app.
ALLOWED_HOSTS=*

DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=300
DB_POOL_TIMEOUT=30
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
